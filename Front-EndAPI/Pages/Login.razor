@page "/login"
@inject AuthService AuthService
@inject NavigationManager Navigation

<h3>Login</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div style="color:red">@errorMessage</div>
}

<div>
    <input placeholder="Username" @bind="loginModel.Username" />
</div>
<div>
    <input placeholder="Password" type="password" @bind="loginModel.Password" />
</div>
<div>
    <button @onclick="HandleLogin" disabled="@isLoading">@(isLoading ? "Logging in..." : "Login")</button>
</div>

@code {
    private LoginModel loginModel = new();
    private string errorMessage = string.Empty;
    private bool isLoading = false;

    private async Task HandleLogin()
    {
        errorMessage = string.Empty;
        isLoading = true;

        try
        {
            var result = await AuthService.Login(loginModel.Username, loginModel.Password);

            if (result)
            {
                Navigation.NavigateTo("/");
            }
            else
            {
                errorMessage = "Invalid username or password.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Login failed: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    public class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
